<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:attr/windowBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/windowBackground"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="?attr/colorOnBackground" />

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Initial/Offline Message -->
        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="32dp"
            android:text="@string/msg_waiting_device"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="visible" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Battery Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBattery"
                    style="?attr/materialCardViewFilledStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="28dp"
                    app:strokeWidth="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <ImageView
                            android:id="@+id/ivBatteryIcon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_lock_idle_charging"
                            app:tint="@color/value_blue" />

                        <LinearLayout
                            android:id="@+id/batteryTextGroup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivBatteryIcon"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvBatteryStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BATTERY"
                                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:alpha="0.7" />

                            <TextView
                                android:id="@+id/tvBatteryValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--%"
                                android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                                android:textColor="@color/value_blue" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvBatteryLife"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="--"
                            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Temperature Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTemp"
                    style="?attr/materialCardViewFilledStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="28dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_temperature"
                            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:alpha="0.7" />

                        <TextView
                            android:id="@+id/tvTemperature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_value"
                            android:textAppearance="@style/TextAppearance.Material3.DisplayMedium"
                            android:textColor="@color/value_blue" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartTemperature"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Light Intensity Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLight"
                    style="?attr/materialCardViewFilledStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="28dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_light"
                            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:alpha="0.7" />

                        <TextView
                            android:id="@+id/tvLight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_value"
                            android:textAppearance="@style/TextAppearance.Material3.DisplayMedium"
                            android:textColor="@color/value_blue" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartLight"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CPU Card (Circular) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCpu"
                    style="?attr/materialCardViewFilledStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="28dp"
                    app:strokeWidth="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <LinearLayout
                            android:id="@+id/cpuTextGroup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CPU LOAD"
                                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:alpha="0.7" />

                            <TextView
                                android:id="@+id/tvCpuLoad"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/default_value"
                                android:textAppearance="@style/TextAppearance.Material3.DisplayMedium"
                                android:textColor="@color/value_blue" />
                        </LinearLayout>

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progressCpu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:indicatorSize="80dp"
                            app:trackThickness="10dp"
                            app:trackCornerRadius="5dp"
                            app:indicatorColor="@color/value_blue"
                            app:trackColor="?attr/colorSurface" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Voltage Card (Graph) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardVoltage"
                    style="?attr/materialCardViewFilledStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="28dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_voltage"
                            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:alpha="0.7" />

                        <TextView
                            android:id="@+id/tvVoltage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_value"
                            android:textAppearance="@style/TextAppearance.Material3.DisplayMedium"
                            android:textColor="@color/value_blue" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartVoltage"
                            android:layout_width="match_parent"
                            android:layout_height="150dp"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Current Card (Graph) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCurrent"
                    style="?attr/materialCardViewFilledStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="28dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_current_now"
                            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:alpha="0.7" />

                        <TextView
                            android:id="@+id/tvCurrentNow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_value"
                            android:textAppearance="@style/TextAppearance.Material3.DisplayMedium"
                            android:textColor="@color/value_blue" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartCurrent"
                            android:layout_width="match_parent"
                            android:layout_height="150dp"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- WiFi Card (Circular RSSI) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWifi"
                    style="?attr/materialCardViewFilledStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="28dp"
                    app:strokeWidth="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_network" android:textAppearance="@style/TextAppearance.Material3.BodyMedium" android:alpha="0.7" />
                            <TextView android:id="@+id/tvNetwork" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/default_value" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textColor="@color/value_blue" android:textStyle="bold" />

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_rssi" android:textAppearance="@style/TextAppearance.Material3.BodyMedium" android:layout_marginTop="8dp" android:alpha="0.7" />
                            <TextView android:id="@+id/tvRSSI" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/default_value" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textColor="@color/value_blue" android:textStyle="bold" />
                        </LinearLayout>

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progressRssi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:indicatorSize="80dp"
                            app:trackThickness="10dp"
                            app:trackCornerRadius="5dp"
                            app:indicatorColor="@color/value_blue"
                            app:trackColor="?attr/colorSurface"
                            android:max="100" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Real-time Log Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLog"
                    style="?attr/materialCardViewFilledStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="28dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_io_log"
                            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:alpha="0.7" />

                        <TextView
                            android:id="@+id/tvLog"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:layout_marginTop="12dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="monospace"
                            android:padding="4dp"
                            android:scrollbars="vertical"
                            android:text="@string/waiting_data"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="@color/secondary_light" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
