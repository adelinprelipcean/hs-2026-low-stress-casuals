<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="12dp"
        android:paddingTop="16dp"
        android:paddingEnd="12dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvIoTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/io_pin_status"
            android:textColor="@color/white"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="269dp"
            android:layout_marginTop="12dp"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="5">

            <LinearLayout
                android:id="@+id/leftPinsColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPIO5"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />

                    <View
                        android:id="@+id/indicatorGpio5"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/pin_indicator_circle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPIO6"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />

                    <View
                        android:id="@+id/indicatorGpio6"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/pin_indicator_circle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPIO7"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />

                    <View
                        android:id="@+id/indicatorGpio7"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/pin_indicator_circle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPIO8"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />

                    <View
                        android:id="@+id/indicatorGpio8"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/pin_indicator_circle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPIO9"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />

                    <View
                        android:id="@+id/indicatorGpio9"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/pin_indicator_circle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPIO10"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />

                    <View
                        android:id="@+id/indicatorGpio10"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/pin_indicator_circle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPIO20"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />

                    <View
                        android:id="@+id/indicatorGpio20"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/pin_indicator_circle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPIO21"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />

                    <View
                        android:id="@+id/indicatorGpio21"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/pin_indicator_circle" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/ivBoard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2.7"
                android:adjustViewBounds="true"
                android:contentDescription="@string/io_board_image_desc"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:scaleType="fitCenter" />

            <LinearLayout
                android:id="@+id/rightPinsColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/indicator5v"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/pin_indicator_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="5V"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/indicatorGnd"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/pin_indicator_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="GND"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/indicator3v3"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/pin_indicator_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="3.3V"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/indicatorGpio4"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/pin_indicator_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="GPIO4"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/indicatorGpio3"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/pin_indicator_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="GPIO3"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/indicatorGpio2"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/pin_indicator_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="GPIO2"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/indicatorGpio1"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/pin_indicator_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="GPIO1"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/indicatorGpio0"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/pin_indicator_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="GPIO0"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/white" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvIoHistoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/io_pin_history"
            android:textColor="@color/white"
            android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

        <GridLayout
            android:id="@+id/pinGraphsGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:columnCount="2"
            android:rowCount="8"
            android:alignmentMode="alignMargins"
            android:useDefaultMargins="false" />
    </LinearLayout>
</ScrollView>
