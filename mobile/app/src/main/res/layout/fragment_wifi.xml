<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        app:cardCornerRadius="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WiFi Connection"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

            <TextView
                android:id="@+id/tvSsid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                android:textColor="@color/value_blue"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tvRssiValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- dBm"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                android:textColor="@color/value_blue"
                android:layout_marginTop="8dp" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressSignal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:indicatorSize="120dp"
                app:trackThickness="12dp"
                android:max="100" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginTop="32dp">

                <TextView android:text="IP Address" android:alpha="0.6"/>
                <TextView android:id="@+id/tvIpAddress" android:text="--" android:gravity="end" android:layout_gravity="fill_horizontal" android:textColor="@color/value_blue" android:textStyle="bold"/>

                <TextView android:text="Channel" android:alpha="0.6" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/tvChannel" android:text="--" android:gravity="end" android:layout_gravity="fill_horizontal" android:layout_marginTop="8dp" android:textColor="@color/value_blue" android:textStyle="bold"/>

                <TextView android:text="Link Speed" android:alpha="0.6" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/tvLinkSpeed" android:text="--" android:gravity="end" android:layout_gravity="fill_horizontal" android:layout_marginTop="8dp" android:textColor="@color/value_blue" android:textStyle="bold"/>
            </GridLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
